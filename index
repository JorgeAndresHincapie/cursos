        <span class="enlace-volver" id="volver-estudiante">← Volver a mis cursos</span>
        <div class="tarjeta">
            <span class="semestre" id="est-semestre"></span>
            <h2 id="est-nombre-curso"></h2>
            <p id="est-descripcion-curso" style="color:#5b6573;"></p>
